# Sentry — leave unset to disable error reporting (default for dev).
# Set in Vercel project settings or your shell before `bun run build`.
VITE_SENTRY_DSN=

# Optional release tag surfaced in Sentry events. Vercel sets this to the
# commit SHA automatically when wired through Project Settings → Environment
# Variables → VITE_RELEASE = $VERCEL_GIT_COMMIT_SHA.
VITE_RELEASE=
